{
  "name": "gigmate-scheduler",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "start": "node dist/server.cjs",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('server.js',{force:true})\"",
    "lint": "tsc --noEmit && eslint ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "6.2.3"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.15",
    "autoprefixer": "^10.4.21",
    "esbuild": "0.25.0",
    "eslint": "^10.3.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "6.2.3"
  }
}
