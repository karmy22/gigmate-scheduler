{
  "name": "gigmate-scheduler",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "start": "node dist/server.cjs",
    "deploy": "npm run build && firebase deploy --only hosting,firestore:rules,functions",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:preview": "npm run build && firebase hosting:channel:deploy preview",
    "deploy:functions": "firebase deploy --only functions",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('server.js',{force:true})\"",
    "lint": "tsc --noEmit && eslint ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "6.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "8.0.14"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "firebase-tools": "^15.18.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.14"
  }
}
